{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "header": "# Changelog",
      "commitUrlFormat": "{{host}}/{{owner}}/{{repository}}/commits/{{hash}}",
      "issueUrlFormat": "{{host}}/{{owner}}/{{repository}}/issues/{{id}}",
      "issuePrefix": "#",
      "releaseNotes": "scripts/generate-release-notes.mjs"
    }
  },
  "hooks": {
    "before:init": ["pnpm lint", "pnpm type-check", "pnpm test"],
    "after:bump": "pnpm build",
    "after:release": "echo Successfully released ${name} v${version} to ${repo.repository_url}"
  },
  "npm": {
    "publish": true,
    "access": "public",
    "otp": null
  },
  "github": {
    "release": true,
    "assets": ["dist/**"],
    "comments": {
      "submit": "Published as {{version}}"
    }
  },
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore: release v${version}",
    "requireCleanWorkingDir": false,
    "force": true
  }
}
